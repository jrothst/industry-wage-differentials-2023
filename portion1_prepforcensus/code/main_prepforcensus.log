. cap program drop readoneyear

. program define readoneyear
  1.   args year
  2.   
.     di "Starting `year'"
  3.         use ${scratch}/extract`year'.dta, clear
  4. 
.         keep serialno sporder st puma mig migsp migpuma agep sex RAC1P schl s
> ch cit pobp ///
>              waob yoep decade relp semp wagp pernp wkhp wkw wrk esr cow fcowp
>  fsemp fwagp ///
>              dis FOD1P hisp indp occp pwgtp naicsp
  5.     // Convert serial no to string if needed
.     cap confirm string variable serialno
  6.     if _rc!=0 tostring serialno, replace format(%13.0f)
  7.         //renames
. 
.         rename st state
  8.         rename mig mobility
  9.         rename pwgtp pweight
 10.         rename migsp state_ly
 11.         rename migpuma puma_ly
 12.         rename agep age
 13.         rename relp relhead
 14.         rename RAC1P race1
 15.         rename pobp pob
 16.         rename waob region_birth
 17.         rename cit citizen
 18.         rename semp selfearn
 19.         rename wagp wagsal
 20.         rename pernp earnings
 21.         rename wkhp hrswkly
 22.         rename wrk workly
 23.         rename dis disabilitty
 24.         rename FOD1P field_degree
 25.         rename indp ind
 26.         rename occp occ
 27.         rename fcowp cowflag
 28.         rename fsemp selfearnflag
 29.         rename fwagp wagsalflag
 30. 
. 
.         gen female=(sex==2)
 31.         tab age female, row col
 32.         tab relhead female, row col
 33. 
.         gen black=(race1==2)
 34.         gen white=(race1==1)
 35.         gen asian=(race1==6)
 36.         gen hispanic=(hisp>=2)
 37. 
.         tab race1 hispanic, row col
 38. 
.         gen wnh=white*(1-hispanic)
 39.         gen bnh=black*(1-hispanic)
 40.         gen anh=asian*(1-hispanic)
 41.         gen other_race=1-hispanic-wnh-bnh-anh
 42. 
.         gen racegroup=1*wnh+2*bnh+3*hispanic+4*anh+5*other_race
 43.         tab racegroup race1, row col
 44. 
. 
.         tab citizen
 45.         gen imm=(citizen>=4)
 46. 
.         tab region_birth imm, row col
 47. 
. 
.         gen educ=(schl-3)
 48.         replace educ=0 if educ<0
 49.         replace educ=11 if schl==15
 50.         replace educ=12 if (schl>=16) & (schl<=18)
 51.         replace educ=13 if schl==19
 52.         replace educ=14 if schl==20
 53.         replace educ=16 if schl==21
 54.         replace educ=18 if schl==22
 55.         replace educ=20 if schl>=23
 56. 
.         tab educ female if age>=25, row col
 57.         tab educ hispanic if age>=25 , row col
 58.         tab educ imm if age>=25, row col
 59. 
. 
. 
. 
.         *var wkw is weeks worked category
.         *1=50-52, 2=48-49, 3=40-47, 4=27-39, 5=14-26, 6=under 14
. 
.         *lets check how wkw varies across gender by education
.         replace wkw=0 if wkw==.
 60.         tab wkw female, row col 
 61.         tab wkw female if educ<=11, row col 
 62.         tab wkw female if educ==12, row col
 63.         tab wkw female if educ>12 & educ<16, row col
 64.         tab wkw female if educ==16 , row col
 65.         tab wkw female if educ>16 , row col
 66. 
.         //assign midpoints
.         gen weeksly=0
 67.         replace weeksly=52 if wkw==1
 68.         replace weeksly=48 if wkw==2
 69.         replace weeksly=44 if wkw==3
 70.         replace weeksly=33 if wkw==4
 71.         replace weeksly=20 if wkw==5
 72.         replace weeksly=7 if wkw==6
 73. 
. 
.         //now hours last year and hourly wages
.         replace hrswkly=0 if hrswkly==.
 74.         tab hrswkly female if hrswkly>0, col
 75. 
.         replace wagsal=0 if wagsal==.
 76.         gen hoursly=hrswkly*weeksly
 77. 
.         gen wage=wagsal/hoursly if hoursly>0 & wagsal>0 
 78.         *winsorized wage
.         gen twage=wage
 79.         replace twage=5 if wage>0 & wage<5
 80.         replace twage=500 if wage>500 & twage~=. 
 81. 
.         gen poshours=(hoursly>0)
 82.         replace poshours=0 if hoursly==.
 83. 
.         tab poshours workly, row col
 84.         tab poshours workly if female==0, row col
 85.         tab poshours workly if female==1, row col
 86. 
. 
. 
.         sum wage twage, detail
 87. 
.         sum hrswkly weeksly hoursly wage twage if female==0
 88.         corr hrswkly weeksly hoursly wage twage if female==0
 89. 
.         sum hrswkly weeksly hoursly wage twage if female==1
 90.         corr hrswkly weeksly hoursly wage twage if female==1
 91.  
. 
. 
.         //mobility since last year (ACS mig variable renamed mobility)
.         //1=same house 2=out of country ly 3=moved within US
. 
.         tab mobility imm, row col
 92. 
.         gen movely=0
 93.         replace movely=1 if mobility>=2
 94. 
.         replace state_ly=state if movely==0
 95.         replace puma_ly=puma if movely==0
 96. 
.         tab state_ly movely if state_ly<100, row
 97. 
.         //special coding for puma 77777  (new orleans parishes)
.         //2010 and 2011 ACS Only - put everyone in puma 1801
.         if `year'<=2011 {
 98.           sum if puma==77777
 99.           replace puma=1801 if state==22 & puma==77777
100.           replace puma_ly=1801 if state_ly==22 & puma_ly==77777
101.     }
102. 
.     // Merge to PUMA list
.     sort state puma serialno sporder
103.     isid state puma serialno sporder
104.     if `year'<=2011 {
105.       merge m:1 state puma using ${scratch}/puma2000_cz, assert(2 3) 
106.     }
107.     if `year'>2011 {
108.       merge m:1 state puma using ${scratch}/puma2010_cz, assert(2 3) 
109.       gen cz10=.
110.       gen af10=.
111.     }
112.         tab _merge
113.         list state puma if _merge==2
114.         keep if _merge==3
115.         drop _merge
116. 
.         tab ncz 
117.         sum cz? cz10 af? af10 afsum
118.         
.     sort serialno sporder
119.     isid serialno sporder
120. 
.     // Arbitrary tiebreakers - these reproduce what was sent to Census in 202
> 1
.     /* 
>     merge 1:1 serialno sporder using ${raw}/tiebreak/tiebreak`year', assert(1
>  3)
>     assert twage==. if _merge==1
>     drop _merge
>     sort sequence serialno sporder
>     */    
.         save ${scratch}/simple`year', replace
121. end

