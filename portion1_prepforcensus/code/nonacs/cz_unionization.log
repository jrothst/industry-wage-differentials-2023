. // Read in unionization from 2010-2018
. local rangeA "A5:I933"

. local rangeB "A5:I1001"

. forvalues y=10/18 {
  2.         if `y'<=14 local range "`rangeA'"
  3.         if `y'>=15 local range "`rangeB'"
  4.         import excel using "${raw}/Hirsch/Met_1`y'.xlsx", cellrange(`range
> ') clear firstrow
  5.         keep if Sector=="Total"
  6.         drop Sector
  7.         gen len=length(Code)
  8.         gen type="CSA" if len==3
  9.         replace type="MSA" if len==5
 10.         drop len
 11.         keep Code MetropolitanArea Obs Employment Mem Cov type
 12.         foreach v of varlist Obs Employment Mem Cov {
 13.                 rename `v' `v'_20`y'
 14.         }
 15.         tempfile union20`y'
 16.         save `union20`y''
 17. }
