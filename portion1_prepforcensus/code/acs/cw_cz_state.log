. 
. local fyear=2010

. local lyear=2018

. 
. *Extract ACS data from CSV to SAS format (because Census programs to read dat
> a
. * are in SAS format only), process/clean, and then convert to Stata
. forvalues yy=`fyear'/`lyear' {
  2.   local y=`yy'-2000
  3.   ! \rm ${tmp}/ss*.csv
  4.   ! \rm ${tmp}/psam*.csv
  5.   ! \rm ${tmp}/acs*.*
  6.   ! \rm ${tmp}/extract`yy'.sas7bdat
  7.   ! \rm ${tmp}/ACS`yy'_PUMS_README.pdf
  8.   
.   di "Starting unzip for `yy'" // Need some displays, as Stata is not verbose
>  about shell commands.
  9.   ! unzip ${acsraw}/csv_pus_`yy'.zip -d ${tmp}
 10. ! ls ${tmp}
 11.   di "Finished unzip for `yy' - starting concatenation"
 12.   if `yy'<=2016 {
 13.     ! cat ${tmp}/ss`y'pusa.csv ${tmp}/ss`y'pusb.csv > ${tmp}/acs`yy'.csv
 14.     ! \rm ${tmp}/ss`y'pus?.csv 
 15.   }
 16.   else {
 17.     ! cat ${tmp}/psam_pusa.csv ${tmp}/psam_pusb.csv > ${tmp}/acs`yy'.csv
 18.     ! \rm ${tmp}/psam_pus?.csv 
 19.   }
 20. ! ls ${tmp}
 21.   di "Finished concatenation for `yy' - starting StatTransfer to SAS"
 22.   ! \rm ${tmp}/acs`yy'.sas7bdat
 23.   ! st ${tmp}/acs`yy'.csv ${tmp}/acs`yy'.sas7bdat
 24. ! ls ${tmp}
 25.   di "Finished StatTransfer to SAS for `yy' - starting SAS extract program
> "
 26.   ! sas extract`y'.sas
 27. ! ls ${tmp}
 28.   di "Finished SAS extract program for `yy' - starting StatTransfer to Sta
> ta"
 29.   ! \rm ${scratch}/extract`yy'.dta
 30.   ! st ${tmp}/extract`yy'.sas7bdat ${scratch}/extract`yy'.dta
 31.   di "Finished StatTransfer to Stata for `yy' - cleaning up"
 32.   ! \rm ${tmp}/acs`yy'.csv
 33.   ! \rm ${tmp}/acs`yy'.sas7bdat
 34.   ! \rm ${tmp}/ACS`yy'_PUMS_README.pdf
 35.   ! \rm ${tmp}/extract`yy'.sas7bdat
 36. }

