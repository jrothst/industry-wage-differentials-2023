  /fontdict fontname findfont def
  /newfont fontdict maxlength dict def
  fontdict {
  exch dup /FID eq {pop pop} {exch newfont 3 1 roll put} ifelse
  } forall
  newfont /FontName newfontname put
  newfontname newfont definefont pop
} def
